DATABASE_URL=postgresql+psycopg://factory:factory@postgres:5432/factory
ASF_DATABASE_URL=postgresql+psycopg://factory:factory@postgres:5432/factory
ASF_ENVIRONMENT=local
ASF_DATA_DIR=/data
ASF_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

ASF_DEFAULT_TENANT_ID=local-dev
ASF_DEFAULT_TENANT_NAME=Local Development
ASF_AUTH_DISABLED=false
ASF_DEV_AUTH_TOKEN=
ASF_OIDC_ISSUER_URL=http://localhost:8081/realms/software-factory
ASF_OIDC_AUDIENCE=software-factory-web
ASF_OIDC_JWKS_URL=http://keycloak:8080/realms/software-factory/protocol/openid-connect/certs

ASF_AGENT_PROVIDER=litellm
ASF_AGENT_STEP_DELAY_MS=900
ASF_WORKFLOW_BACKEND=temporal
ASF_TEMPORAL_ADDRESS=temporal:7233
ASF_TEMPORAL_NAMESPACE=default
ASF_TEMPORAL_TASK_QUEUE=software-factory

ASF_LITELLM_BASE_URL=http://litellm:4000
ASF_LITELLM_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ASF_DEFAULT_MODEL=openrouter/openai/gpt-4o-mini
ASF_MODEL_MONTHLY_BUDGET_USD=250

ASF_MCP_ENABLED=true
ASF_MCP_REGISTRY_PATH=/data/mcp/servers.json

ASF_SANDBOX_BACKEND=kubernetes
ASF_SANDBOX_NAMESPACE=software-factory-sandbox
ASF_SANDBOX_RUNTIME_CLASS=
ASF_SANDBOX_IMAGE=asf-sandbox-runner:local
ASF_DOCKER_KUBECONFIG=./data/kube/asf-local-internal.kubeconfig
ASF_SANDBOX_KUBECONFIG=/kube/config
ASF_SANDBOX_WORKSPACE_PVC=asf-sandbox-workspaces
ASF_SANDBOX_WORKSPACE_MOUNT_PATH=/workspace
ASF_SANDBOX_ALLOWED_COMMANDS=python -m pytest generated_app/tests

ASF_S3_ENDPOINT_URL=http://minio:9000
ASF_S3_BUCKET=software-factory-artifacts
ASF_S3_ACCESS_KEY_ID=minioadmin
ASF_S3_SECRET_ACCESS_KEY=minioadmin

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_TENANT_ID=local-dev
NEXT_PUBLIC_OIDC_ISSUER_URL=http://localhost:8081/realms/software-factory
NEXT_PUBLIC_OIDC_CLIENT_ID=software-factory-web
