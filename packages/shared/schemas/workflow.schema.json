{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workflow",
  "type": "object",
  "required": ["graph"],
  "properties": {
    "graph": {
      "type": "object",
      "required": ["id", "version", "nodes", "edges"],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" },
        "nodes": { "type": "array" },
        "edges": { "type": "array" }
      }
    }
  }
}
